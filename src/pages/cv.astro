---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="CV"
  description="Kun-Han Lee — AI Algorithm Software Engineer at NVIDIA. CV, experience, education and skills."
>
  <section class="page-content">
    <div class="container">

      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={base}>首頁</a>
        <span class="breadcrumb-separator">/</span>
        <span>CV</span>
      </nav>

      <div class="cv-wrap">

        <!-- ── Header ── -->
        <div class="cv-header">
          <div class="cv-header-left">
            <h1 class="cv-name">Kun-Han Lee</h1>
            <p class="cv-title">AI Algorithm Software Engineer · NVIDIA</p>
          </div>
          <div class="cv-header-right">
            <a href="mailto:kunhanl0511@gmail.com" class="cv-contact-link">✉ kunhanl0511@gmail.com</a>
            <a href="https://linkedin.com/in/kunhanl0511" target="_blank" rel="noopener" class="cv-contact-link">in kunhanl0511</a>
            <a href="https://github.com/leekunhan" target="_blank" rel="noopener" class="cv-contact-link">⌥ github.com/leekunhan</a>
            <span class="cv-contact-link">📍 Taipei, Taiwan</span>
          </div>
        </div>

        <div class="cv-download-bar">
          <a href={`${base}/Kun-Han-Lee_CV.pdf`} download class="cv-download-btn">↓ Download PDF</a>
        </div>

        <!-- ── Experience ── -->
        <div class="cv-section">
          <h2 class="cv-section-title">Experience</h2>

          <div class="cv-entry">
            <div class="cv-entry-header">
              <div>
                <span class="cv-entry-company">NVIDIA</span>
                <span class="cv-entry-role"> · AI Algorithm Software Engineer</span>
              </div>
              <div class="cv-entry-meta">Taipei, Taiwan · Sept 2025 – Present</div>
            </div>
            <p class="cv-entry-summary">Full-time · Hybrid</p>
          </div>

          <div class="cv-entry">
            <div class="cv-entry-header">
              <div>
                <span class="cv-entry-company">NVIDIA</span>
                <span class="cv-entry-role"> · Solution Architect Intern</span>
              </div>
              <div class="cv-entry-meta">Taipei, Taiwan · Dec 2023 – Sept 2025</div>
            </div>
            <ul class="cv-list">
              <li>Delivered Omniverse/SDG-based solutions for industrial inspection use cases (e.g., AOI workflow support for customers such as Gigabyte).</li>
              <li>Built synthetic data generation pipelines with Isaac Sim Replicator, enabling controllable variations (angle/material/location/size) and boosting throughput to 69 images/min (~1000 images/15 mins) vs. manual collection.</li>
              <li>Supported LLM RAG implementations for enterprise scenarios (e.g., training-data generation and log file analysis), including an RAG + Agent (ReAct) workflow design.</li>
              <li>Partnered with Foxconn teams to integrate cuOpt + Isaac Cloud Services (ICS) + Kit SDK into an Omniverse factory environment for simulation and verification; contributed to SDG-related demos (e.g., lighting sampling / defect image generation).</li>
              <li>Created reusable enablement assets such as an SDG Reference Extension and Sizing Project to help partners validate hardware requirements and ramp up on Omniverse standalone scripts.</li>
            </ul>
          </div>
        </div>

        <!-- ── Education ── -->
        <div class="cv-section">
          <h2 class="cv-section-title">Education</h2>

          <div class="cv-entry">
            <div class="cv-entry-header">
              <div>
                <span class="cv-entry-company">National Taiwan University of Science and Technology</span>
                <span class="cv-entry-role"> · M.S. Industrial Management</span>
              </div>
              <div class="cv-entry-meta">Taipei, Taiwan · Jan 2024 – Aug 2025</div>
            </div>
            <ul class="cv-list">
              <li>Activities: Decision and Analytics Lab (AIDA Lab)</li>
              <li>Skills: OOP · Large Language Models · Omniverse · Object Detection</li>
            </ul>
          </div>

          <div class="cv-entry">
            <div class="cv-entry-header">
              <div>
                <span class="cv-entry-company">National Taiwan University of Science and Technology</span>
                <span class="cv-entry-role"> · B.S. Industrial Management</span>
              </div>
              <div class="cv-entry-meta">Taipei, Taiwan · Sept 2020 – Jan 2024</div>
            </div>
            <ul class="cv-list">
              <li>GPA: 3.89</li>
              <li>Activities: Department volleyball team, Department student association</li>
              <li>Skills: Industrial Engineering · C++</li>
            </ul>
          </div>

          <div class="cv-entry">
            <div class="cv-entry-header">
              <div>
                <span class="cv-entry-company">National Taiwan University of Science and Technology</span>
                <span class="cv-entry-role"> · Minor, Computer Science and Information Engineering</span>
              </div>
              <div class="cv-entry-meta">Taipei, Taiwan · Sept 2021 – Jan 2024</div>
            </div>
            <ul class="cv-list">
              <li>GPA: 4.1 / 4.3</li>
              <li>Skills: OOP · Python · C++</li>
            </ul>
          </div>
        </div>

        <!-- ── Industry-Academia ── -->
        <div class="cv-section">
          <h2 class="cv-section-title">Industry-Academia Collaboration</h2>

          <div class="cv-entry">
            <div class="cv-entry-header">
              <div><span class="cv-entry-company">GIGABYTE</span><span class="cv-entry-role"> · Research on Transfer Learning and Few-Shot Learning</span></div>
            </div>
            <ul class="cv-list">
              <li>Developed digital twin virtual environments.</li>
              <li>Used virtual data generation to address challenges in limited data collection and data acquisition.</li>
            </ul>
          </div>

          <div class="cv-entry">
            <div class="cv-entry-header">
              <div><span class="cv-entry-company">AUO</span><span class="cv-entry-role"> · Research on Multimodal Language Models in Defect Detection</span></div>
            </div>
            <ul class="cv-list">
              <li>Leveraged retrieval-augmented generation to support training for multimodal language models.</li>
            </ul>
          </div>

          <div class="cv-entry">
            <div class="cv-entry-header">
              <div><span class="cv-entry-company">MAtek</span><span class="cv-entry-role"> · Use T-CAD Simulation Data to Improve Semiconductor Measurement</span></div>
            </div>
            <ul class="cv-list">
              <li>Built customized T-CAD simulation workflows using Omniverse Kit.</li>
            </ul>
          </div>
        </div>

        <!-- ── Two-column bottom ── -->
        <div class="cv-two-col">

          <div>
            <!-- Skills -->
            <div class="cv-section">
              <h2 class="cv-section-title">Skills</h2>
              <div class="cv-skills">
                {[
                  { label: "Languages", detail: "Python · C++" },
                  { label: "AI / ML", detail: "Large Language Models · Deep Learning · Object Detection" },
                  { label: "Platforms", detail: "NVIDIA Omniverse" },
                  { label: "Dev Tools", detail: "Docker · Git · GitHub" },
                  { label: "Domain", detail: "Industrial Engineering" },
                  { label: "Human Lang", detail: "English (TOEIC Gold) · Mandarin (Native)" },
                ].map(s => (
                  <div class="cv-skill-row">
                    <span class="cv-skill-label">{s.label}</span>
                    <span class="cv-skill-detail">{s.detail}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- Certifications -->
            <div class="cv-section">
              <h2 class="cv-section-title">Certifications</h2>
              <div class="cv-entry">
                <div class="cv-entry-header">
                  <span class="cv-entry-company">TOEIC Gold Certificate</span>
                  <span class="cv-entry-meta">Mar 2025</span>
                </div>
                <p class="cv-entry-summary">TOEIC Program · Credential ID: 25014188</p>
              </div>
              <div class="cv-entry">
                <div class="cv-entry-header">
                  <span class="cv-entry-company">Develop, Customize, and Publish in Omniverse With Extensions</span>
                  <span class="cv-entry-meta">Jul 2024</span>
                </div>
                <p class="cv-entry-summary">NVIDIA · Credential ID: Lr1_PJ8VSFu4MUHH-23M6A</p>
              </div>
              <div class="cv-entry">
                <div class="cv-entry-header">
                  <span class="cv-entry-company">Introduction to Transformer-Based NLP</span>
                  <span class="cv-entry-meta">Jan 2024</span>
                </div>
                <p class="cv-entry-summary">NVIDIA · Credential ID: 1e385396677d45a2abe95c2f10cc982d</p>
              </div>
            </div>
          </div>

          <div>
            <!-- Honors -->
            <div class="cv-section">
              <h2 class="cv-section-title">Selected Honors</h2>
              <ul class="cv-honors-list">
                <li>Fubon Life Management PhD and Master's Thesis Award — Best Practice Paper <span class="cv-honor-org">Chinese Management Association, 2025</span></li>
                <li>TSMC IMC Large Language Model Application Competition — Silver Prize <span class="cv-honor-org">TSMC, 2024</span></li>
                <li>2024 CIIE Best Paper <span class="cv-honor-org">CIIE, 2024</span></li>
                <li>中華民國斐陶斐（Phi Tau Phi）榮譽會員 <span class="cv-honor-org">斐陶斐榮譽學會, 2024</span></li>
                <li>第二十六屆決策分析研討會 — 最佳論文<br /><small>論文：數位孿生與人工智慧於工廠內標籤識別應用</small> <span class="cv-honor-org">2024</span></li>
              </ul>
            </div>
          </div>

        </div>

      </div><!-- /cv-wrap -->
    </div>
  </section>
</BaseLayout>

<style>
  .cv-wrap {
    max-width: 860px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .cv-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid var(--color-border, #e5e7eb);
    margin-bottom: 0.75rem;
  }
  .cv-name {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
    color: var(--color-text-heading, #1a1a1a);
  }
  .cv-title {
    font-size: 0.95rem;
    color: var(--color-accent, #4a9078);
    margin: 0;
    font-weight: 500;
  }
  .cv-header-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.3rem;
  }
  .cv-contact-link {
    font-size: 0.78rem;
    color: var(--color-text-muted, #6b7280);
    text-decoration: none;
  }
  .cv-contact-link:hover { color: var(--color-accent, #4a9078); }

  /* ── Download bar ── */
  .cv-download-bar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 2rem;
  }
  .cv-download-btn {
    display: inline-block;
    background: var(--color-accent, #4a9078);
    color: #fff;
    text-decoration: none;
    font-size: 0.8rem;
    padding: 0.4rem 1rem;
    border-radius: 6px;
    transition: opacity 0.2s;
  }
  .cv-download-btn:hover { opacity: 0.85; }

  /* ── Section ── */
  .cv-section {
    margin-bottom: 2rem;
  }
  .cv-section-title {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent, #4a9078);
    font-weight: 700;
    margin: 0 0 0.75rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }

  /* ── Entry ── */
  .cv-entry {
    margin-bottom: 1.1rem;
  }
  .cv-entry-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.3rem;
  }
  .cv-entry-company {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-text-heading, #1a1a1a);
  }
  .cv-entry-role {
    font-size: 0.88rem;
    color: var(--color-text, #374151);
  }
  .cv-entry-meta {
    font-size: 0.76rem;
    color: var(--color-text-muted, #6b7280);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .cv-entry-summary {
    font-size: 0.8rem;
    color: var(--color-text-muted, #6b7280);
    margin: 0.15rem 0 0;
    font-style: italic;
  }
  .cv-list {
    margin: 0.4rem 0 0 1.2rem;
    padding: 0;
    font-size: 0.85rem;
    color: var(--color-text, #374151);
    line-height: 1.65;
  }
  .cv-list li { margin-bottom: 0.3rem; }

  /* ── Two-column ── */
  .cv-two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  /* ── Skills ── */
  .cv-skills { display: flex; flex-direction: column; gap: 0.4rem; }
  .cv-skill-row {
    display: flex;
    gap: 0.6rem;
    font-size: 0.83rem;
    line-height: 1.5;
  }
  .cv-skill-label {
    min-width: 80px;
    font-weight: 600;
    color: var(--color-text-heading, #1a1a1a);
    flex-shrink: 0;
  }
  .cv-skill-detail { color: var(--color-text, #374151); }

  /* ── Honors ── */
  .cv-honors-list {
    margin: 0 0 0 1.2rem;
    padding: 0;
    font-size: 0.85rem;
    color: var(--color-text, #374151);
    line-height: 1.65;
  }
  .cv-honors-list li { margin-bottom: 0.55rem; }
  .cv-honor-org {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted, #6b7280);
  }

  @media (max-width: 680px) {
    .cv-header { flex-direction: column; }
    .cv-header-right { align-items: flex-start; }
    .cv-two-col { grid-template-columns: 1fr; }
    .cv-entry-header { flex-direction: column; gap: 0.1rem; }
  }
</style>
