---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="旅遊紀錄"
  description="探索世界各地的美食、住宿與景點，分享旅行經驗與攻略"
>
  <section class="page-content">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={base}>首頁</a>
        <span class="breadcrumb-separator">/</span>
        <span>旅遊</span>
      </nav>

      <div class="section-header">
        <h1>🌏 旅遊紀錄</h1>
        <p class="section-subtitle">
          走過的路、看過的風景、嚐過的美味，都是人生中珍貴的回憶。
          這裡記錄了我的旅行足跡與心得分享。
        </p>
      </div>

      <div class="card-grid">
        <Card
          href={`${base}/travel/food`}
          title="🍜 美食"
          description="沖繩在地美食探索，13 間精選餐廳完整介紹。"
        />
        <Card
          href={`${base}/travel/home`}
          title="🏨 住宿"
          description="旅途中的落腳處，住宿體驗與推薦。"
        />
        <Card
          href={`${base}/travel/location`}
          title="📍 景點"
          description="沖繩必訪景點完整指南，從世界遺產到海灘度假區。"
        />
        <Card
          href={`${base}/travel/okinawa`}
          title="🏝️ 沖繩"
          description="最新遊記：沖繩五日四夜完整攻略，涵蓋交通、美食、景點與行程規劃。"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="article-content">
        <h2>旅行哲學</h2>
        <p>
          旅行對我來說，不只是換個地方生活，更是一種學習與成長的過程。
          每到一個新的地方，我總是嘗試融入當地的生活節奏，
          體驗在地文化，品嚐道地美食。
        </p>
        <p>
          這個區塊將持續更新我的旅行紀錄，希望能為正在規劃旅程的你提供一些參考與靈感。
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
