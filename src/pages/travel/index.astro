---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="旅遊紀錄"
  description="探索世界各地的美食、住宿與景點，分享旅行經驗與攻略"
>
  <section class="page-content">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={base}>首頁</a>
        <span class="breadcrumb-separator">/</span>
        <span>旅遊</span>
      </nav>

      <div class="section-header">
        <h1>🌏 旅遊紀錄</h1>
        <p class="section-subtitle">
          走過的路、看過的風景、嚐過的美味，都是人生中珍貴的回憶。
        </p>
      </div>

      <div class="card-grid">
        <Card
          href={`${base}/travel/okinawa`}
          title="🏝️ 沖繩"
          description="五日四夜完整攻略：行程規劃、美食餐廳、必訪景點與住宿推薦。"
        />
        <Card
          href={`${base}/travel/chiangmai`}
          title="🌿 清邁"
          description="泰北古城慢活之旅，古寺、街頭美食與山區健行。"
        />
        <Card
          href={`${base}/travel/bangkok`}
          title="🏙️ 曼谷"
          description="充滿活力的泰國首都，廟宇、夜市與街頭美食。"
        />
        <Card
          href={`${base}/travel/osaka`}
          title="🍜 大阪"
          description="日本關西美食之都，道頓堀、章魚燒與環球影城。"
        />
        <Card
          href={`${base}/travel/tokyo`}
          title="🗼 東京"
          description="傳統與現代並存的日本首都，每個街區都有不同的驚喜。"
        />
        <Card
          href={`${base}/travel/busan`}
          title="🌊 釜山"
          description="韓國港口城市，海鮮、彩色山城與絕美海灘。"
        />
      </div>
    </div>
  </section>
</BaseLayout>
