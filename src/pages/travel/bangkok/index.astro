---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---
<BaseLayout title="曼谷旅遊指南" description="曼谷旅遊攻略：廟宇、街頭美食、夜市與購物商圈，泰國首都完整導覽。">
  <section class="page-content">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={base}>首頁</a>
        <span class="breadcrumb-separator">/</span>
        <a href={`${base}/travel`}>旅遊</a>
        <span class="breadcrumb-separator">/</span>
        <span>曼谷</span>
      </nav>
      <div class="section-header">
        <h1>🏙️ 曼谷旅遊指南</h1>
        <p class="section-subtitle">充滿活力的泰國首都，廟宇與街頭美食的奇妙共存。</p>
      </div>
      <div class="article-content">
        <p>內容整理中，敬請期待！</p>
      </div>
    </div>
  </section>
</BaseLayout>
