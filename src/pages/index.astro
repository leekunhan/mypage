---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Home"
  description="Kun-Han Lee (李昆翰) - Engineer at NVIDIA. Tech notes, travel records and life sharing."
>
  <section class="hero">
    <div class="container">
      <h1>Hello! I'm Kun-Han Lee 👋</h1>
      <p class="hero-subtitle">
        李昆翰，NVIDIA 工程師。熱愛技術、旅行與探索新事物。<br />
        歡迎來到我的個人網站！
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">探索更多</h2>
        <p class="section-subtitle">選擇你感興趣的內容</p>
      </div>

      <div class="card-grid">
        <Card
          href={`${base}/chatbot`}
          title="💬 MarsRhino Chatbot"
          description="AI 智能助手，即將上線！可以問我任何關於這個網站的問題。"
        />
        <Card
          href={`${base}/travel`}
          title="🌏 旅遊紀錄"
          description="探索世界各地的美食、住宿與景點，分享我的旅行經驗。"
        />
        <Card
          href={`${base}/diving`}
          title="🤿 潛水日記"
          description="記錄水肺潛水與自由潛水的海底世界，分享潛點、裝備與每次下水的心得。"
        />
        <Card
          href={`${base}/travel/okinawa`}
          title="🏝️ 沖繩五日遊"
          description="最新遊記：沖繩的陽光、海灘與美食，完整攻略分享。"
        />
        <Card
          href="https://github.com/leekunhan"
          title="🔧 GitHub"
          description="查看我的開源專案與程式碼，歡迎交流與合作。"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">關於我</h2>
      </div>
      <div class="article-content">
        <p>
          我是 <strong>Kun-Han Lee（李昆翰）</strong>，目前任職於 <strong>NVIDIA</strong> 擔任工程師，
          base 在台灣台北。專注於 3D 技術、合成資料生成與 AI 應用開發。
        </p>

        <h2>🛠️ 技術專長</h2>

        <h3>NVIDIA 技術</h3>
        <ul>
          <li>NVIDIA Omniverse</li>
          <li>USD（通用場景描述）</li>
          <li>合成資料生成（Synthetic Data Generation）</li>
        </ul>

        <h3>AI 與機器學習</h3>
        <ul>
          <li>MLOps</li>
          <li>深度學習（Deep Learning）</li>
          <li>大型語言模型（LLMs）</li>
          <li>電腦視覺（Computer Vision）</li>
        </ul>

        <h3>程式開發</h3>
        <ul>
          <li>JavaScript / React</li>
          <li>資料視覺化（Data Visualization）</li>
          <li>電腦圖學（Computer Graphics）</li>
        </ul>

        <h2>🚀 代表專案</h2>

        <h3>AI 智能助手平台</h3>
        <p>使用 JavaScript 開發的互動式 AI 對話助手平台，整合多種 LLM 能力。</p>

        <h3>Omniverse 合成資料生成</h3>
        <p>
          基於 NVIDIA Omniverse 的合成資料生成工具，應用於 AI 訓練資料集建立。
          <a href="https://github.com/leekunhan" target="_blank" rel="noopener">GitHub →</a>
        </p>

        <h3>GTC Talk — Empower Virtual Collaboration</h3>
        <p>於 NVIDIA GTC 發表的技術演講，探討虛擬協作的未來與技術實現。
          <a href="https://www.nvidia.com/en-us/on-demand/session/gtc24-s63282/" target="_blank" rel="noopener">Watch →</a>
        </p>

        <h2>📬 聯絡方式</h2>
        <ul>
          <li>Email：<a href="mailto:kunhanl0511@gmail.com">kunhanl0511@gmail.com</a></li>
          <li>Location：Taipei, Taiwan</li>
          <li>GitHub：<a href="https://github.com/leekunhan" target="_blank" rel="noopener">github.com/leekunhan</a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
