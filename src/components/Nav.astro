---
const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;

function isActive(path: string): boolean {
  if (path === '/') return pathname === base || pathname === `${base}/`;
  return pathname.startsWith(`${base}${path}`);
}
---

<nav class="main-nav" aria-label="Main navigation">
  <a href={`${base}/`} class:list={['nav-link', { active: isActive('/') }]}>首頁</a>
  <a href={`${base}/chatbot`} class:list={['nav-link', { active: isActive('/chatbot') }]}>Chatbot</a>
  <a href={`${base}/cv`} class:list={['nav-link', { active: isActive('/cv') }]}>CV</a>

  <div class="nav-dropdown">
    <a href={`${base}/diving`} class:list={['nav-link', { active: isActive('/diving') }]}>
      潛水 ▾
    </a>
    <div class="nav-dropdown-content">
      <a href={`${base}/diving/scuba`} class:list={['nav-dropdown-link', { active: isActive('/diving/scuba') }]}>🧜 水肺潛水</a>
      <a href={`${base}/diving/freediving`} class:list={['nav-dropdown-link', { active: isActive('/diving/freediving') }]}>🌊 自由潛水</a>
    </div>
  </div>

  <div class="nav-dropdown">
    <a href={`${base}/travel`} class:list={['nav-link', { active: isActive('/travel') }]}>
      旅遊 ▾
    </a>
    <div class="nav-dropdown-content">

      <div class="nav-dropdown-nested">
        <a href={`${base}/travel/okinawa`} class:list={['nav-dropdown-link', { active: isActive('/travel/okinawa') }]}>
          🏝️ 沖繩 ▶
        </a>
        <div class="nav-dropdown-nested-content">
          <a href={`${base}/travel/okinawa/itinerary`} class:list={['nav-dropdown-link', { active: isActive('/travel/okinawa/itinerary') }]}>五日行程</a>
          <a href={`${base}/travel/okinawa/food`} class:list={['nav-dropdown-link', { active: isActive('/travel/okinawa/food') }]}>美食</a>
          <a href={`${base}/travel/okinawa/location`} class:list={['nav-dropdown-link', { active: isActive('/travel/okinawa/location') }]}>景點</a>
          <a href={`${base}/travel/okinawa/home`} class:list={['nav-dropdown-link', { active: isActive('/travel/okinawa/home') }]}>住宿</a>
        </div>
      </div>

      <a href={`${base}/travel/chiangmai`} class:list={['nav-dropdown-link', { active: isActive('/travel/chiangmai') }]}>🌿 清邁</a>
      <a href={`${base}/travel/bangkok`} class:list={['nav-dropdown-link', { active: isActive('/travel/bangkok') }]}>🏙️ 曼谷</a>
      <a href={`${base}/travel/osaka`} class:list={['nav-dropdown-link', { active: isActive('/travel/osaka') }]}>🍜 大阪</a>
      <a href={`${base}/travel/tokyo`} class:list={['nav-dropdown-link', { active: isActive('/travel/tokyo') }]}>🗼 東京</a>
      <a href={`${base}/travel/busan`} class:list={['nav-dropdown-link', { active: isActive('/travel/busan') }]}>🌊 釜山</a>

    </div>
  </div>
</nav>
