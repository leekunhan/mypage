---
const base = import.meta.env.BASE_URL; // '/mypage'
const pathname = Astro.url.pathname;

function isActive(path: string): boolean {
  if (path === '/') return pathname === base || pathname === `${base}/`;
  return pathname.startsWith(`${base}${path}`);
}

const navItems = [
  { href: `${base}/`, path: '/', label: 'й¦–й Ѓ' },
  { href: `${base}/chatbot`, path: '/chatbot', label: 'Chatbot' },
  {
    href: `${base}/travel`, path: '/travel',
    label: 'ж—…йЃЉ',
    children: [
      { href: `${base}/travel/food`, path: '/travel/food', label: 'зѕЋйЈџ' },
      { href: `${base}/travel/home`, path: '/travel/home', label: 'дЅЏе®ї' },
      { href: `${base}/travel/location`, path: '/travel/location', label: 'ж™Їй»ћ' },
      { href: `${base}/travel/okinawa`, path: '/travel/okinawa', label: 'жІ–з№©' },
    ]
  },
];
---

<nav class="main-nav" aria-label="Main navigation">
  {navItems.map((item) => (
    item.children ? (
      <div class="nav-dropdown">
        <a href={item.href} class:list={['nav-link', { active: isActive(item.path) }]}>
          {item.label} в–ѕ
        </a>
        <div class="nav-dropdown-content">
          {item.children.map((child) => (
            <a href={child.href} class:list={['nav-dropdown-link', { active: isActive(child.path) }]}>
              {child.label}
            </a>
          ))}
        </div>
      </div>
    ) : (
      <a href={item.href} class:list={['nav-link', { active: isActive(item.path) }]}>
        {item.label}
      </a>
    )
  ))}
</nav>
